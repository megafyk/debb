{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ServiceRepoMap",
  "type": "object",
  "required": ["ticket_id", "evidence_session_id", "services"],
  "properties": {
    "ticket_id": { "type": "string" },
    "evidence_session_id": { "type": "string" },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["service_name", "repository", "relevance_reason"],
        "properties": {
          "service_name": { "type": "string" },
          "repository": { "type": "string" },
          "relevance_reason": { "type": "string" },
          "repo_instructions_read": { "type": "array", "items": { "type": "string" } },
          "code_review_graph_available": { "type": "boolean" },
          "graph_queries_used": { "type": "array", "items": { "type": "string" } },
          "suspected_code_paths": { "type": "array", "items": { "type": "string" } },
          "suspected_functions": { "type": "array", "items": { "type": "string" } },
          "related_tests": { "type": "array", "items": { "type": "string" } },
          "log_fields": { "type": "array", "items": { "type": "string" } },
          "db_entities": { "type": "array", "items": { "type": "string" } },
          "sql_references_from_code": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
