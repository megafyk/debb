{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QuickwitQueryPlan",
  "type": "object",
  "required": ["type", "evidence_session_id", "service", "datasource_uid", "from", "to", "query_intent", "filters", "fields_requested", "max_hits"],
  "properties": {
    "type": { "type": "string", "const": "quickwit_query_plan" },
    "evidence_session_id": { "type": "string" },
    "service": { "type": "string" },
    "repository": { "type": "string" },
    "code_paths": { "type": "array", "items": { "type": "string" } },
    "datasource_uid": { "type": "string" },
    "from": { "type": "string", "description": "ISO 8601, epoch ms, or Grafana relative (e.g. now-1h)" },
    "to": { "type": "string", "description": "ISO 8601, epoch ms, or Grafana relative (e.g. now)" },
    "ref_id": { "type": "string", "default": "A" },
    "max_data_points": { "type": "integer", "minimum": 1, "default": 100 },
    "interval_ms": { "type": "integer", "minimum": 1, "default": 1000 },
    "query_intent": { "type": "string" },
    "filters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "op"],
        "properties": {
          "field": { "type": "string" },
          "op": { "type": "string", "enum": ["=", "!=", "in", "not_in", "contains", "matches_sensitive_ref"] },
          "value": {},
          "value_ref": { "type": "string" }
        }
      }
    },
    "fields_requested": { "type": "array", "items": { "type": "string" } },
    "max_hits": { "type": "integer", "minimum": 1, "maximum": 1000 },
    "output_profile": { "type": "string" }
  }
}
